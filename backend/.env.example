# Catalyst Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://catalyst.com,https://www.catalyst.com

# ── Email (Nodemailer) ───────────────────────────────────
# SMTP configuration for sending contact form notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email addresses
FROM_EMAIL=noreply@catalyst.com
FROM_NAME=Catalyst
TO_EMAIL=hello@catalyst.com

# ── Rate Limiting ────────────────────────────────────────
# Max requests per window (15 minutes) for contact/newsletter APIs
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=900000

# ── Security ─────────────────────────────────────────────
# Secret for CSRF tokens (generate a random 32-char string)
SESSION_SECRET=change-me-to-a-random-32-char-string
